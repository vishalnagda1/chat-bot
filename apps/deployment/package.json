    "@repo/types": "workspace:*",
    "@repo/events": "workspace:*",
    "@repo/auth-middleware": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^9.0.0",
    "drizzle-orm": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
